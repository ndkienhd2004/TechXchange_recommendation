DB_NAME=techxchange
DB_USER=postgres
DB_PASS=postgres
DB_HOST=localhost
DB_PORT=5432

APP_HOST=0.0.0.0
APP_PORT=8010
LOG_LEVEL=info
APP_RELOAD=false

EVENT_LOOKBACK_DAYS=60
POPULARITY_LOOKBACK_DAYS=30
REFRESH_INTERVAL_MINUTES=15

GEMINI_API_KEY=your_gemini_api_key
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_EMBED_DIM=768
GEMINI_BATCH_SIZE=32
GEMINI_TIMEOUT_SECONDS=30
EMBEDDING_CACHE_PATH=.cache/gemini_item_embeddings.json
CF_MIN_SIMILARITY=0.05
CF_MAX_NEIGHBORS=50
HYBRID_CONTENT_WEIGHT=0.6
